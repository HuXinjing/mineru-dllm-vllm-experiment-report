+            return FakeResponse()
+
+    monkeypatch.setattr(
+        "benchmarks.mineru_diffusion.end2end_openai.requests.Session",
+        FakeSession,
+    )
+
+    client = End2EndOpenAIClient(
+        endpoint="http://host/v1/chat/completions",
